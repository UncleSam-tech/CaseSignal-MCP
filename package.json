{
  "name": "casesignal-mcp",
  "version": "1.0.0",
  "description": "Federal court litigation intelligence MCP server",
  "type": "module",
  "main": "dist/app/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/app/server.ts",
    "start": "node dist/app/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed-aliases.ts",
    "db:refresh-snapshots": "tsx scripts/refreshSnapshots.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ctxprotocol/sdk": "^0.9.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.0.0",
    "pg": "^8.11.0",
    "uuid": "^10.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "ajv": "^8.18.0",
    "supertest": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
