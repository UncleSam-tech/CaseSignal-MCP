# Server
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
LOG_LEVEL=info

# CourtListener (required)
COURTLISTENER_API_TOKEN=
COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4

# PACER / RECAP fallback (optional — enables stale docket refresh)
PACER_USERNAME=
PACER_PASSWORD=
PACER_CLIENT_CODE=

# Database
DATABASE_URL=postgresql://casesignal:password@localhost:5432/casesignal

# Redis
REDIS_URL=redis://localhost:6379

# MCP Server
MCP_SERVER_NAME=casesignal-mcp
MCP_SERVER_VERSION=1.0.0

# Context Protocol
CONTEXT_JWT_AUDIENCE=
CONTEXT_JWT_ISSUER=
CONTEXT_SHARED_SECRET=

# Fetch webhook (for async RECAP fetch callbacks)
FETCH_WEBHOOK_SECRET=

# Tuning
COLD_FETCH_TIMEOUT_MS=25000
SNAPSHOT_TTL_SECONDS=3600
WARM_CACHE_TTL_SECONDS=900
DEFAULT_LOOKBACK_MONTHS=60
MAX_CASES_PER_QUERY=10
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Feature flags
ENABLE_EXECUTE_MODE=false
ENABLE_FETCH_FALLBACK=true
